<div class="flex flex-col gap-2 text-sm text-muted-foreground">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Já tenho conta · Entrar", new_session_path(resource_name),
        class: "text-primary font-medium hover:opacity-80 transition-smooth" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Criar minha conta", new_registration_path(resource_name),
        class: "text-primary font-medium hover:opacity-80 transition-smooth" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Esqueci minha senha", new_password_path(resource_name),
        class: "hover:text-foreground transition-smooth" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Reenviar instruções de confirmação", new_confirmation_path(resource_name),
        class: "hover:text-foreground transition-smooth" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Reenviar instruções de desbloqueio", new_unlock_path(resource_name),
        class: "hover:text-foreground transition-smooth" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Entrar com #{OmniAuth::Utils.camelize(provider)}",
          omniauth_authorize_path(resource_name, provider),
          data: { turbo: false },
          class: "inline-flex items-center justify-center w-full rounded-xl border border-border bg-card px-4 py-2.5 text-sm font-medium text-foreground hover:bg-surface transition-smooth" %>
    <% end %>
  <% end %>
</div>
