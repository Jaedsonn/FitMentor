<div class="flex min-h-screen w-full">
  <%= render "devise/shared/brand_panel",
      heading: "Bem-vindo de volta ao seu progresso.",
      subheading: "Acesse sua conta para acompanhar mentorias, sessões e a evolução do seu treino." %>

  <section class="flex w-full lg:w-1/2 items-center justify-center px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="w-full max-w-md space-y-8">
      <div class="lg:hidden flex items-center gap-3">
        <%= render "devise/shared/fitmentor_logo" %>
        <span class="text-xl font-extrabold tracking-tight text-foreground">
          Fit<span class="text-gradient-primary">Mentor</span>
        </span>
      </div>

      <header class="space-y-2">
        <h1 class="text-3xl lg:text-4xl font-bold tracking-tight text-foreground">
          Entrar na sua conta
        </h1>
        <p class="text-sm text-muted-foreground">
          Novo no FitMentor?
          <%= link_to "Criar conta", new_registration_path(resource_name),
              class: "text-primary font-medium hover:opacity-80 transition-smooth" %>
        </p>
      </header>

      <%
        field_wrap = "space-y-2"
        label_cls  = "block text-sm font-medium text-foreground"
        input_cls  = "block w-full rounded-xl border border-border bg-card px-3.5 py-2.5 text-sm text-foreground placeholder:text-muted-foreground shadow-card focus:border-primary focus:outline-none focus:ring-1 focus:ring-ring transition-smooth"
      %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <div class="<%= field_wrap %>">
          <%= f.label :email, "E-mail", class: label_cls %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "voce@exemplo.com", class: input_cls %>
        </div>

        <div class="<%= field_wrap %>">
          <div class="flex items-center justify-between">
            <%= f.label :password, "Senha", class: label_cls %>
            <% if devise_mapping.recoverable? %>
              <%= link_to "Esqueci a senha", new_password_path(resource_name),
                  class: "text-xs font-medium text-primary hover:opacity-80 transition-smooth" %>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: "current-password", class: input_cls %>
        </div>

        <% if devise_mapping.rememberable? %>
          <label class="flex items-center gap-2 text-sm text-foreground select-none">
            <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-border text-primary focus:ring-1 focus:ring-ring" %>
            <span>Manter-me conectado</span>
          </label>
        <% end %>

        <%= f.submit "Entrar",
            class: "w-full inline-flex items-center justify-center rounded-xl bg-gradient-primary px-4 py-3 text-sm font-semibold text-primary-foreground shadow-primary hover:opacity-95 hover:-translate-y-0.5 active:translate-y-0 transition-smooth focus:outline-none focus:ring-1 focus:ring-ring focus:ring-offset-2 focus:ring-offset-background cursor-pointer" %>
      <% end %>

      <% if devise_mapping.confirmable? || (devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email)) || devise_mapping.omniauthable? %>
        <div class="pt-4 border-t border-border">
          <%= render "devise/shared/links" %>
        </div>
      <% end %>
    </div>
  </section>
</div>
